# Aillium Remote (MeshCentral) - Environment Configuration (placeholders only)

# Service binding
MESHCENTRAL_HOST=0.0.0.0
MESHCENTRAL_PORT=443

# Public URL (what agents/clients connect to)
MESHCENTRAL_PUBLIC_URL=https://remote.example.com

# Cookie / session secret (set to a strong random value in production via Vault)
MESHCENTRAL_COOKIE_SECRET=

# Data storage path (container volume)
MESHCENTRAL_DATA_PATH=/opt/meshcentral-data

# TLS
# If terminating TLS at a reverse proxy, set these empty and terminate externally.
MESHCENTRAL_TLS_CERT_PATH=
MESHCENTRAL_TLS_KEY_PATH=

# Admin bootstrap (DO NOT set real values in repo; use runtime secrets)
MESHCENTRAL_ADMIN_USER=
MESHCENTRAL_ADMIN_PASSWORD=

# Aillium integration (executor-only)
AILLIUM_ENV=production
AILLIUM_TENANT_TAG_PREFIX=tenant_

# Logging/observability placeholders
LOG_LEVEL=info

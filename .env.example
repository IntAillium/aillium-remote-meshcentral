# aillium-remote-meshcentral v1 environment template
# Placeholders only. Do not commit real secrets.

# Runtime environment
NODE_ENV=production

# Public endpoint presented by reverse proxy
MESHCENTRAL_PUBLIC_FQDN=remote.example.com
MESHCENTRAL_PUBLIC_URL=https://remote.example.com

# Internal meshcentral listener (reverse proxy forwards here)
MESHCENTRAL_BIND_ADDRESS=0.0.0.0
MESHCENTRAL_INTERNAL_PORT=4430

# Optional HTTP redirect listener (internal only)
MESHCENTRAL_HTTP_REDIRECT_PORT=8080

# Bootstrap placeholders (set via secret manager at deploy time)
MESHCENTRAL_ADMIN_USERNAME=<set-at-runtime>
MESHCENTRAL_ADMIN_PASSWORD=<set-at-runtime>
MESHCENTRAL_SESSION_COOKIE_SECRET=<set-at-runtime>

# Database connectivity (placeholder)
MESHCENTRAL_USE_MONGODB=true
MESHCENTRAL_MONGO_URL=mongodb://<user>:<password>@mongodb:27017/meshcentral

# Persistence paths (container-local mount points)
MESHCENTRAL_DATA_PATH=/opt/meshcentral/meshcentral-data
MESHCENTRAL_FILES_PATH=/opt/meshcentral/meshcentral-files
MESHCENTRAL_BACKUPS_PATH=/opt/meshcentral/meshcentral-backups

# Tenant model defaults
AILLIUM_TENANT_GROUP_PREFIX=tenant-

# Logging
LOG_LEVEL=info
